CMDCTL=zig-out/bin/cmdctl

# Serial transport.
CMD_SERIAL_PORT=/dev/cu.usbmodem11401
CMD_SERIAL_BAUD=115200
CMD_SERIAL_COMMAND_PREFIX=cmd

# BT/KCP transport.
CMD_BT_ADDR=
CMD_BT_SERVICE_UUID=FEE0
CMD_BT_TX_CHAR_UUID=FEE1
CMD_BT_RX_CHAR_UUID=FEE2

# Desktop TCP pseudo-serial transport.
CMD_TCP_ADDR=127.0.0.1
CMD_TCP_PORT=39074
CMD_TCP_START_SERVER=1

# Board flashing.
CMD_DEVKIT_BOARD=devkit
CMD_FLASH_PORT=/dev/cu.usbmodem11401
CMD_FLASH_BEFORE_TEST=0
CMD_ESP_IDF=/Users/idy/esp/esp-idf-v6.0

# BK board flashing.
CMD_BK_BOARD=bk7258_v3_2024
CMD_BK_SERIAL_PORT=/dev/cu.usbserial-1134320
CMD_ARMINO_SDK_PATH=/Users/idy/armino/bk_avdk_smp_v3.1.1
CMD_BK_LOADER_PATH=
CMD_FLASH_BK_BEFORE_TEST=0
