{
  "kind": "UserStory",
  "spec": {
    "name": "modem attach sequence",
    "description": "walks sim, registration, and packet attachment changes one tick at a time",
    "steps": [
      {
        "inputs": [
          {
            "modem_sim_state_changed": {
              "source_id": 51,
              "sim": "locked"
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 1,
          "n": 1
        }
      },
      {
        "outputs": [
          {
            "label": "cell",
            "state": {
              "source_id": 51,
              "sim": "locked",
              "registration": "offline",
              "packet": "detached",
              "signal": null,
              "apn_end": 0
            }
          }
        ]
      },
      {
        "inputs": [
          {
            "modem_sim_state_changed": {
              "source_id": 51,
              "sim": "ready"
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 1,
          "n": 1
        }
      },
      {
        "outputs": [
          {
            "label": "cell",
            "state": {
              "source_id": 51,
              "sim": "ready",
              "registration": "offline",
              "packet": "detached",
              "signal": null,
              "apn_end": 0
            }
          }
        ]
      },
      {
        "inputs": [
          {
            "modem_network_registration_changed": {
              "source_id": 51,
              "registration": "searching"
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 1,
          "n": 1
        }
      },
      {
        "outputs": [
          {
            "label": "cell",
            "state": {
              "source_id": 51,
              "sim": "ready",
              "registration": "searching",
              "packet": "detached",
              "signal": null,
              "apn_end": 0
            }
          }
        ]
      },
      {
        "inputs": [
          {
            "modem_network_registration_changed": {
              "source_id": 51,
              "registration": "home"
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 1,
          "n": 1
        }
      },
      {
        "outputs": [
          {
            "label": "cell",
            "state": {
              "source_id": 51,
              "sim": "ready",
              "registration": "home",
              "packet": "detached",
              "signal": null,
              "apn_end": 0
            }
          }
        ]
      },
      {
        "inputs": [
          {
            "modem_data_packet_state_changed": {
              "source_id": 51,
              "packet": "attaching"
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 1,
          "n": 1
        }
      },
      {
        "outputs": [
          {
            "label": "cell",
            "state": {
              "source_id": 51,
              "sim": "ready",
              "registration": "home",
              "packet": "attaching",
              "signal": null,
              "apn_end": 0
            }
          }
        ]
      },
      {
        "inputs": [
          {
            "modem_data_packet_state_changed": {
              "source_id": 51,
              "packet": "connected"
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 1,
          "n": 1
        }
      },
      {
        "outputs": [
          {
            "label": "cell",
            "state": {
              "source_id": 51,
              "sim": "ready",
              "registration": "home",
              "packet": "connected",
              "signal": null,
              "apn_end": 0
            }
          }
        ]
      }
    ]
  }
}
