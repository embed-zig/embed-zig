/*
 * Curated LVGL configuration template for embed-zig.
 *
 * This is intentionally not a full copy of upstream LVGL configuration.
 * Anything not defined here will still fall back to LVGL's internal defaults.
 */

#ifndef LV_CONF_H
#define LV_CONF_H

/*====================
 * Color settings
 *====================*/

/* Valid values: 1, 8, 16, 24, 32 */
#undef LV_COLOR_DEPTH

/*=========================
 * Stdlib wrapper settings
 *=========================*/

/*
 * Valid values:
 *   LV_STDLIB_BUILTIN
 *   LV_STDLIB_CLIB
 *   LV_STDLIB_MICROPYTHON
 *   LV_STDLIB_RTTHREAD
 *   LV_STDLIB_CUSTOM
 */
#undef LV_USE_STDLIB_MALLOC
#undef LV_USE_STDLIB_STRING
#undef LV_USE_STDLIB_SPRINTF

/* Only used when LV_USE_STDLIB_MALLOC == LV_STDLIB_BUILTIN */
#undef LV_MEM_SIZE

/*================
 * OS integration
 *================*/

/*
 * This template does not configure LVGL's OS backend directly.
 *
 * `build/pkg/lvgl.zig` fills these in automatically:
 *
 *   LV_USE_OS = LV_OS_CUSTOM
 *   LV_OS_CUSTOM_INCLUDE = "lv_os_custom.h"
 *
 * These placeholders are not intended to be set from this template directly.
 */
#undef LV_USE_OS

/* Placeholder only; embed-zig fills this automatically in the default config path. */
#undef LV_OS_CUSTOM_INCLUDE

/*=================
 * Core features
 *=================*/

/* Use float as lv_value_precise_t */
#undef LV_USE_FLOAT

/* Requires LV_USE_FLOAT == 1 */
#undef LV_USE_MATRIX

/* Observer / subject support */
#undef LV_USE_OBSERVER

#endif /* LV_CONF_H */
