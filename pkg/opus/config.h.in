#ifndef OPUS_CONFIG_H
#define OPUS_CONFIG_H

/*
 * Curated Opus configuration template for embed-zig.
 *
 * Copy this file to your app, replace the `#undef` lines you need with
 * concrete `#define` values, then pass the finished header via:
 *   -Dopus=true -Dopus_config_header=path/to/config.h
 */

/* Required for the fixed-point build used by this package. */
#undef FIXED_POINT
#undef OPUS_BUILD

/*
 * Temporary allocation backend: choose exactly one.
 * embed-zig defaults to VAR_ARRAYS unless you provide a custom header.
 */
#undef VAR_ARRAYS
#undef USE_ALLOCA
#undef NONTHREADSAFE_PSEUDOSTACK

/* Math capability probes used by float_cast.h. */
#undef HAVE_LRINT
#undef HAVE_LRINTF

/*
 * Default to disabling the float API.
 * To enable the float API in a copied header, leave this macro undefined.
 */
#undef DISABLE_FLOAT_API

/* Optional upstream knobs. Leave undefined unless you need them. */
#undef CUSTOM_MODES
#undef ENABLE_HARDENING

#endif /* OPUS_CONFIG_H */
