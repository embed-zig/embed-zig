{
  "kind": "UserStory",
  "spec": {
    "name": "grouped button long press sequence",
    "description": "holds grouped button 3 and observes long press growth",
    "steps": [
      {
        "inputs": [
          {
            "raw_grouped_button": {
              "source_id": 8,
              "button_id": 3,
              "pressed": true
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 500000000,
          "n": 1
        }
      },
      {
        "outputs": [
          {
            "label": "grouped_button",
            "state": {
              "source_id": 8,
              "button_id": 3,
              "gesture_kind": "long_press",
              "click_count": 0,
              "long_press_ns": 500000000
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 100000000,
          "n": 1
        }
      },
      {
        "outputs": [
          {
            "label": "grouped_button",
            "state": {
              "source_id": 8,
              "button_id": 3,
              "gesture_kind": "long_press",
              "click_count": 0,
              "long_press_ns": 600000000
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 150000000,
          "n": 1
        }
      },
      {
        "outputs": [
          {
            "label": "grouped_button",
            "state": {
              "source_id": 8,
              "button_id": 3,
              "gesture_kind": "long_press",
              "click_count": 0,
              "long_press_ns": 750000000
            }
          }
        ]
      },
      {
        "inputs": [
          {
            "raw_grouped_button": {
              "source_id": 8,
              "button_id": 3,
              "pressed": false
            }
          }
        ]
      }
    ]
  }
}
