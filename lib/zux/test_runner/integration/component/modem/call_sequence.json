{
  "kind": "UserStory",
  "spec": {
    "name": "modem call sequence",
    "description": "tracks an incoming call from ringing to active to remote hangup",
    "steps": [
      {
        "inputs": [
          {
            "modem_call_incoming": {
              "source_id": 51,
              "call_id": 7,
              "direction": "incoming",
              "number_end": 5,
              "number_buf": "10086"
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 1,
          "n": 1
        }
      },
      {
        "outputs": [
          {
            "label": "cell",
            "state": {
              "source_id": 51,
              "call": {
                "call_id": 7,
                "direction": "incoming",
                "state": "incoming",
                "end_reason": null,
                "number_end": 5,
                "number_buf": "10086"
              }
            }
          }
        ]
      },
      {
        "inputs": [
          {
            "modem_call_state_changed": {
              "source_id": 51,
              "call_id": 7,
              "direction": "incoming",
              "state": "active",
              "number_end": 5,
              "number_buf": "10086"
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 1,
          "n": 1
        }
      },
      {
        "outputs": [
          {
            "label": "cell",
            "state": {
              "source_id": 51,
              "call": {
                "call_id": 7,
                "direction": "incoming",
                "state": "active",
                "end_reason": null,
                "number_end": 5,
                "number_buf": "10086"
              }
            }
          }
        ]
      },
      {
        "inputs": [
          {
            "modem_call_ended": {
              "source_id": 51,
              "call_id": 7,
              "reason": "remote_hangup"
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 1,
          "n": 1
        }
      },
      {
        "outputs": [
          {
            "label": "cell",
            "state": {
              "source_id": 51,
              "call": {
                "call_id": 7,
                "direction": "incoming",
                "state": null,
                "end_reason": "remote_hangup",
                "number_end": 5,
                "number_buf": "10086"
              }
            }
          }
        ]
      }
    ]
  }
}
