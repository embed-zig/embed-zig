{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "allowSyntheticDefaultImports": true,
    "types": [
      "bun-types"
    ]
  },
  "include": [
    "mock/**/*.ts",
    "e2e/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "openapi-ts.config.ts",
    "playwright.config.ts"
  ]
}
