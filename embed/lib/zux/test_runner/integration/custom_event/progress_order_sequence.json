{
  "kind": "UserStory",
  "spec": {
    "name": "custom progress ordered sequence",
    "description": "dispatches multiple registered custom event types in order and ignores an unrelated registered type.",
    "initial_state": {
      "progress": {
        "seen": false,
        "source_id": 0,
        "value": 0,
        "updates": 0,
        "reset_count": 0,
        "last_kind": "none"
      }
    },
    "steps": [
      {
        "inputs": [
          {
            "custom": {
              "type": "test.progress.set",
              "source_id": 1,
              "payload": {
                "value": 10
              }
            }
          },
          {
            "custom": {
              "type": "test.progress.delta",
              "source_id": 2,
              "payload": {
                "amount": 5
              }
            }
          },
          {
            "custom": {
              "type": "test.progress.ignored",
              "source_id": 3,
              "payload": {
                "marker": 99
              }
            }
          },
          {
            "custom": {
              "type": "test.progress.delta",
              "source_id": 4,
              "payload": {
                "amount": 8
              }
            }
          }
        ],
        "outputs": [
          {
            "label": "progress",
            "state": {
              "seen": true,
              "source_id": 4,
              "value": 23,
              "updates": 3,
              "reset_count": 0,
              "last_kind": "delta"
            }
          }
        ]
      }
    ]
  }
}
