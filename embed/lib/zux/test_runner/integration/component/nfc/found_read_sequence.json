{
  "kind": "UserStory",
  "spec": {
    "name": "nfc found read sequence",
    "description": "captures an ndef card discovery and the later payload read using the shared reader id",
    "initial_state": {
      "single_button": {},
      "grouped_button": {},
      "strip": {},
      "sensor": {},
      "cell": {},
      "reader": {},
      "sta": {},
      "ap": {},
      "pairing": { "node": "idle" },
      "loading": {},
      "menu": { "count": 3, "loop": true },
      "route": { "current_page": 1 }
    },
    "steps": [
      {
        "inputs": [
          {
            "nfc_found": {
              "source_id": 21,
              "uid_end": 4,
              "buf": [
                4,
                161,
                178,
                195
              ],
              "card_type": "ndef"
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 1,
          "n": 1
        }
      },
      {
        "outputs": [
          {
            "label": "reader",
            "state": {
              "source_id": 21,
              "uid_end": 4,
              "payload_end": 4,
              "buf": [
                4,
                161,
                178,
                195
              ],
              "card_type": "ndef"
            }
          }
        ]
      },
      {
        "inputs": [
          {
            "nfc_read": {
              "source_id": 21,
              "uid_end": 4,
              "payload_end": 8,
              "buf": [
                4,
                161,
                178,
                195,
                3,
                2,
                209,
                1
              ],
              "card_type": "ndef"
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 1,
          "n": 1
        }
      },
      {
        "outputs": [
          {
            "label": "reader",
            "state": {
              "source_id": 21,
              "uid_end": 4,
              "payload_end": 8,
              "buf": [
                4,
                161,
                178,
                195,
                3,
                2,
                209,
                1
              ],
              "card_type": "ndef"
            }
          }
        ]
      }
    ]
  }
}
