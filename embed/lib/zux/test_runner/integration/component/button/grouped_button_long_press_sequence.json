{
  "kind": "UserStory",
  "spec": {
    "name": "grouped button long press sequence",
    "description": "holds grouped button 3 and observes long press growth",
    "initial_state": {
      "single_button": {},
      "grouped_button": {},
      "strip": {},
      "sensor": {},
      "cell": {},
      "reader": {},
      "sta": {},
      "ap": {},
      "pairing": { "node": "idle" },
      "loading": {},
      "menu": { "count": 3, "loop": true },
      "route": { "current_page": 1 }
    },
    "steps": [
      {
        "inputs": [
          {
            "raw_grouped_button": {
              "source_id": 8,
              "button_id": 3,
              "pressed": true
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 500000000,
          "n": 1
        }
      },
      {
        "outputs": [
          {
            "label": "grouped_button",
            "state": {
              "source_id": 8,
              "button_id": 3,
              "gesture_kind": "long_press",
              "click_count": 0,
              "long_press": 500000000
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 100000000,
          "n": 1
        }
      },
      {
        "outputs": [
          {
            "label": "grouped_button",
            "state": {
              "source_id": 8,
              "button_id": 3,
              "gesture_kind": "long_press",
              "click_count": 0,
              "long_press": 600000000
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 150000000,
          "n": 1
        }
      },
      {
        "outputs": [
          {
            "label": "grouped_button",
            "state": {
              "source_id": 8,
              "button_id": 3,
              "gesture_kind": "long_press",
              "click_count": 0,
              "long_press": 750000000
            }
          }
        ]
      },
      {
        "inputs": [
          {
            "raw_grouped_button": {
              "source_id": 8,
              "button_id": 3,
              "pressed": false
            }
          }
        ]
      }
    ]
  }
}
