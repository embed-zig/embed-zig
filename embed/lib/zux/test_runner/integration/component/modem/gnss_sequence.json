{
  "kind": "UserStory",
  "spec": {
    "name": "modem gnss sequence",
    "description": "tracks gnss acquisition, a fixed position, and the later idle reset",
    "initial_state": {
      "single_button": {},
      "grouped_button": {},
      "strip": {},
      "sensor": {},
      "cell": {},
      "reader": {},
      "sta": {},
      "ap": {},
      "pairing": { "node": "idle" },
      "loading": {},
      "menu": { "count": 3, "loop": true },
      "route": { "current_page": 1 }
    },
    "steps": [
      {
        "inputs": [
          {
            "modem_gnss_state_changed": {
              "source_id": 51,
              "state": "acquiring"
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 1,
          "n": 1
        }
      },
      {
        "outputs": [
          {
            "label": "cell",
            "state": {
              "source_id": 51,
              "gnss_state": "acquiring",
              "gnss_fix": null
            }
          }
        ]
      },
      {
        "inputs": [
          {
            "modem_gnss_fix_changed": {
              "source_id": 51,
              "fix": {
                "quality": "three_d",
                "latitude_deg": 31.2304,
                "longitude_deg": 121.4737,
                "altitude_m": 12.5,
                "satellites_in_view": 12,
                "satellites_used": 8
              }
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 1,
          "n": 1
        }
      },
      {
        "outputs": [
          {
            "label": "cell",
            "state": {
              "source_id": 51,
              "gnss_state": "fixed",
              "gnss_fix": {
                "quality": "three_d",
                "latitude_deg": 31.2304,
                "longitude_deg": 121.4737,
                "satellites_used": 8
              }
            }
          }
        ]
      },
      {
        "inputs": [
          {
            "modem_gnss_state_changed": {
              "source_id": 51,
              "state": "idle"
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 1,
          "n": 1
        }
      },
      {
        "outputs": [
          {
            "label": "cell",
            "state": {
              "source_id": 51,
              "gnss_state": "idle",
              "gnss_fix": null
            }
          }
        ]
      }
    ]
  }
}
