{
  "kind": "UserStory",
  "spec": {
    "name": "imu flip then shake sequence",
    "description": "sets flip motion, clears it, then sets shake motion and clears it again",
    "steps": [
      {
        "inputs": [
          {
            "imu_motion": {
              "source_id": 17,
              "motion": {
                "flip": {
                  "from": "up",
                  "to": "down"
                }
              }
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 1,
          "n": 1
        },
        "outputs": [
          {
            "label": "sensor",
            "state": {
              "motion": "flip"
            }
          }
        ]
      },
      {
        "inputs": [
          {
            "raw_imu_accel": {
              "source_id": 17,
              "x": 0.0,
              "y": 0.0,
              "z": -1.0
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 1,
          "n": 1
        },
        "outputs": [
          {
            "label": "sensor",
            "state": {
              "motion": null
            }
          }
        ]
      },
      {
        "inputs": [
          {
            "imu_motion": {
              "source_id": 17,
              "motion": {
                "shake": {
                  "magnitude": 2.4,
                  "duration": 100000000
                }
              }
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 1,
          "n": 1
        },
        "outputs": [
          {
            "label": "sensor",
            "state": {
              "motion": "shake"
            }
          }
        ]
      },
      {
        "inputs": [
          {
            "raw_imu_accel": {
              "source_id": 17,
              "x": 0.0,
              "y": 0.0,
              "z": -1.0
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 1,
          "n": 1
        },
        "outputs": [
          {
            "label": "sensor",
            "state": {
              "motion": null
            }
          }
        ]
      }
    ]
  }
}
