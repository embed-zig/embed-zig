{
  "kind": "UserStory",
  "spec": {
    "name": "imu free fall sequence",
    "description": "sets free-fall motion and clears it with the next accel sample",
    "steps": [
      {
        "inputs": [
          {
            "imu_motion": {
              "source_id": 17,
              "motion": {
                "free_fall": {
                  "duration": 180000000,
                  "min_magnitude": 0.03
                }
              }
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 1,
          "n": 1
        },
        "outputs": [
          {
            "label": "sensor",
            "state": {
              "motion": "free_fall"
            }
          }
        ]
      },
      {
        "inputs": [
          {
            "raw_imu_accel": {
              "source_id": 17,
              "x": 0.0,
              "y": 0.0,
              "z": 1.0
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 1,
          "n": 1
        },
        "outputs": [
          {
            "label": "sensor",
            "state": {
              "motion": null
            }
          }
        ]
      }
    ]
  }
}
