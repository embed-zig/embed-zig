+void ikcp_allocator(void* (*new_malloc)(size_t), void (*new_free)(void*))
+{
+	ikcp_malloc_hook = new_malloc;
+	ikcp_free_hook = new_free;
+}
+
+static void* ikcp_alloc_malloc(const IKCPALLOC *alloc, size_t size)
+{
+	if (alloc && alloc->malloc_fn) {
+		return alloc->malloc_fn(alloc->ctx, size);
+	}
+	return ikcp_malloc(size);
+}
+
+static void ikcp_alloc_free(const IKCPALLOC *alloc, void *ptr)
+{
+	if (alloc && alloc->free_fn) {
+		alloc->free_fn(alloc->ctx, ptr);
+	} else {
+		ikcp_free(ptr);
+	}
+}
+
+static void* ikcp_malloc_kcp(ikcpcb *kcp, size_t size)
+{
+	return ikcp_alloc_malloc(&kcp->alloc, size);
+}
+
+static void ikcp_free_kcp(ikcpcb *kcp, void *ptr)
+{
+	ikcp_alloc_free(&kcp->alloc, ptr);
+}
+
+// allocate a new kcp segment
+static IKCPSEG* ikcp_segment_new(ikcpcb *kcp, int size)
+{
+	return (IKCPSEG*)ikcp_malloc_kcp(kcp, sizeof(IKCPSEG) + size);
+}
+
+// delete a segment
+static void ikcp_segment_delete(ikcpcb *kcp, IKCPSEG *seg)
+{
+	ikcp_free_kcp(kcp, seg);
+}
 
