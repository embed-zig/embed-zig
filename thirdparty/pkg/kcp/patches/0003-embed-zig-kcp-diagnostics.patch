diff --git a/ikcp.c b/ikcp.c
index d76c4166..c204c546 100644
--- a/ikcp.c
+++ b/ikcp.c
@@ -352,0 +353,8 @@ ikcpcb* ikcp_create_with_allocator(IUINT32 conv, void *user, IKCPALLOC alloc)
+	kcp->diag_output_new = 0;
+	kcp->diag_output_fast = 0;
+	kcp->diag_output_rto = 0;
+	kcp->diag_output_ack = 0;
+	kcp->diag_output_wask = 0;
+	kcp->diag_output_wins = 0;
+	kcp->diag_input_ack = 0;
+	kcp->diag_input_push = 0;
@@ -941,0 +950 @@ int ikcp_input(ikcpcb *kcp, const char *data, long size)
+			kcp->diag_input_ack++;
@@ -971,0 +981 @@ int ikcp_input(ikcpcb *kcp, const char *data, long size)
+			kcp->diag_input_push++;
@@ -1141,0 +1152 @@ void ikcp_flush(ikcpcb *kcp)
+		kcp->diag_output_ack++;
@@ -1176,0 +1188 @@ void ikcp_flush(ikcpcb *kcp)
+		kcp->diag_output_wask++;
@@ -1187,0 +1200 @@ void ikcp_flush(ikcpcb *kcp)
+		kcp->diag_output_wins++;
@@ -1247,0 +1261 @@ void ikcp_flush(ikcpcb *kcp)
+		int send_reason = 0;
@@ -1249,0 +1264 @@ void ikcp_flush(ikcpcb *kcp)
+			send_reason = 1;
@@ -1255,0 +1271 @@ void ikcp_flush(ikcpcb *kcp)
+			send_reason = 3;
@@ -1271,0 +1288 @@ void ikcp_flush(ikcpcb *kcp)
+				send_reason = 2;
@@ -1295,0 +1313,8 @@ void ikcp_flush(ikcpcb *kcp)
+			if (send_reason == 1) {
+				kcp->diag_output_new++;
+			} else if (send_reason == 2) {
+				kcp->diag_output_fast++;
+			} else if (send_reason == 3) {
+				kcp->diag_output_rto++;
+			}
+
