              "gain_db": 0,
              "min_gain_db": -60,
              "max_gain_db": 6,
              "gain_step_db": 1
            }
          },
          {
            "label": "display",
            "state": {
              "enabled": true,
              "brightness": 255
            }
          },
          {
            "label": "display_driver",
            "state": {
              "rendered": true
            }
          }
        ]
      }
    ]
  }
}
