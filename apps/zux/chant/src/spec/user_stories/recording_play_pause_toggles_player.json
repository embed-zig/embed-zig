{
  "kind": "UserStory",
  "spec": {
    "name": "recording play pause toggles player",
    "description": "While recording, Play/Pause still toggles playback without changing recording, player.selected, or audio.gain_db.",
    "initial_state": {
      "play_pause": {},
      "boot": {},
      "next": {},
      "previous": {},
      "volume_up": {},
      "volume_down": {},
      "controls": {},
