      "ble_link": { "role": "server", "phase": "running", "connected": true, "subscribed": false, "conn_handle": 64, "conn_interval": 24, "att_mtu": 256, "payload_len": 253, "service_uuid": 65248, "tx_char_uuid": 65249, "rx_char_uuid": 65250, "last_error_code": 0 },
      "tx_stats": { "running": true, "window_ms": 1000, "tx_seq": 0, "rx_expected_seq": 4, "tx_bytes_total": 0, "rx_bytes_total": 1024, "tx_packets_total": 0, "rx_packets_total": 4, "rx_lost_packets": 0, "rx_reordered_packets": 0, "rx_duplicate_packets": 0, "tx_bps": 0, "rx_bps": 0, "tx_pps": 0, "rx_pps": 0 }
    },
    "steps": [ { "inputs": [ { "custom": { "type": "ble_speed_test.rx_packet", "source_id": 1, "payload": { "seq": 4, "bytes": 253, "window_ms": 1000 } } } ], "outputs": [ { "label": "tx_stats", "state": { "rx_expected_seq": 5, "rx_lost_packets": 0, "rx_reordered_packets": 0, "rx_duplicate_packets": 0 } } ] } ]
  }
