{
  "kind": "UserStory",
  "spec": {
    "name": "server mtu exchange updates payload len",
    "description": "A server-side MTU update stores att_mtu and derives payload_len as att_mtu minus ATT header length.",
    "initial_state": {
      "boot": {},
      "display": { "enabled": true, "brightness": 255 },
      "ble_link": { "role": "server", "phase": "running", "connected": true, "subscribed": false, "conn_handle": 64, "conn_interval": 24, "att_mtu": 23, "payload_len": 20, "service_uuid": 65248, "tx_char_uuid": 65249, "rx_char_uuid": 65250, "last_error_code": 0 },
      "tx_stats": { "running": false, "window_ms": 1000, "tx_seq": 0, "rx_expected_seq": 0, "tx_bytes_total": 0, "rx_bytes_total": 0, "tx_packets_total": 0, "rx_packets_total": 0, "rx_lost_packets": 0, "rx_reordered_packets": 0, "rx_duplicate_packets": 0, "tx_bps": 0, "rx_bps": 0, "tx_pps": 0, "rx_pps": 0 }
    },
    "steps": [
      { "inputs": [ { "ble_periph_mtu_changed": { "source_id": 1, "conn_handle": 64, "mtu": 256 } } ], "outputs": [
        { "label": "ble_link", "state": { "att_mtu": 256, "payload_len": 253 } },
        { "label": "display_driver", "state": { "rendered": true } }
      ] }
    ]
  }
}
