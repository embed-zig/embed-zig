      "tx_stats": { "running": true, "window_ms": 1000, "tx_seq": 0, "rx_expected_seq": 0, "tx_bytes_total": 0, "rx_bytes_total": 0, "tx_packets_total": 0, "rx_packets_total": 0, "rx_lost_packets": 0, "rx_reordered_packets": 0, "rx_duplicate_packets": 0, "tx_bps": 0, "rx_bps": 0, "tx_pps": 0, "rx_pps": 0 }
