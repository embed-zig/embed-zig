    "steps": [ { "inputs": [ { "custom": { "type": "ble_speed_test.tx_packet", "source_id": 1, "payload": { "seq": 1, "bytes": 253, "window_ms": 1000 } } } ], "outputs": [ { "label": "display_driver", "state": { "rendered": true } } ] } ]
