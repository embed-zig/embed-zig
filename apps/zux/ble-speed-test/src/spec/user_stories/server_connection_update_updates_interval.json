{
  "kind": "UserStory",
  "spec": {
    "name": "server connection update updates interval",
    "description": "Server link interval reflects a later BLE connection update event.",
    "initial_state": {
      "boot": {},
      "display": { "enabled": true, "brightness": 255 },
      "ble_link": { "role": "server", "phase": "running", "connected": true, "subscribed": false, "conn_handle": 64, "conn_interval": 24, "att_mtu": 256, "payload_len": 253, "service_uuid": 65248, "tx_char_uuid": 65249, "rx_char_uuid": 65250, "last_error_code": 0 },
      "tx_stats": { "running": true, "window_ms": 1000, "tx_seq": 0, "rx_expected_seq": 0, "tx_bytes_total": 0, "rx_bytes_total": 0, "tx_packets_total": 0, "rx_packets_total": 0, "rx_lost_packets": 0, "rx_reordered_packets": 0, "rx_duplicate_packets": 0, "tx_bps": 0, "rx_bps": 0, "tx_pps": 0, "rx_pps": 0 }
    },
    "steps": [ { "inputs": [ { "ble_periph_connection_updated": { "source_id": 1, "conn_handle": 64, "peer_addr": [1, 2, 3, 4, 5, 6], "peer_addr_type": "public", "interval": 12, "latency": 0, "supervision_timeout": 3000000000 } } ], "outputs": [ { "label": "ble_link", "state": { "conn_interval": 12 } }, { "label": "display_driver", "state": { "rendered": true } } ] } ]
  }
}
