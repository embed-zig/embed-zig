{
  "kind": "UserStory",
  "spec": {
    "name": "color lerp does not emit target on first tick",
    "description": "The first 10ms tick from red toward blue does not show blue immediately.",
    "initial_state": {
      "button": {},
      "strip": {},
      "scene": {
        "mode": "solid",
        "target_color_name": "blue",
        "target_color": 255,
        "visible_color": 16711680,
        "transitioning": true,
        "marquee_stage": "none"
      }
    },
    "steps": [
      {
        "tick": {
          "interval": 10000000,
          "n": 1
        },
        "outputs": [
          {
            "label": "scene",
            "state": {
              "visible_color": 15663120,
              "transitioning": true
            }
          }
        ]
      }
    ]
  }
}
