{
  "kind": "UserStory",
  "spec": {
    "name": "rainbow tick advances palette",
    "description": "When the LED strip is in rainbow mode, the user waits for animation ticks and the rainbow stage advances",
    "initial_state": {
      "button": {},
      "strip": {},
      "scene": {
        "mode": 0,
        "rainbow_stage": 0
      }
    },
    "steps": [
      {
        "outputs": [
          {
            "label": "scene",
            "state": {
              "mode": 0,
              "rainbow_stage": 0
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 120000000,
          "n": 50
        },
        "outputs": [
          {
            "label": "scene",
            "state": {
              "mode": 4,
              "rainbow_stage": 0
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 120000000,
          "n": 3
        },
        "outputs": [
          {
            "label": "scene",
            "state": {
              "mode": 4,
              "rainbow_stage": 3
            }
          }
        ]
      }
    ]
  }
}
