{
  "kind": "UserStory",
  "spec": {
    "name": "marquee close to yellow targets blue",
    "description": "When marquee reaches yellow, the next 10ms tick targets blue.",
    "initial_state": {
      "boot": {},
      "strip": {},
      "scene": {
        "mode": "marquee",
        "target_color_name": "yellow",
        "target_color": 16776960,
        "visible_color": 16776960,
        "transitioning": false,
        "marquee_stage": "yellow"
      }
    },
    "steps": [
      {
        "outputs": [
          {
            "label": "scene",
            "state": {
              "mode": "marquee",
              "target_color_name": "yellow",
              "target_color": 16776960,
              "visible_color": 16776960,
              "transitioning": false,
              "marquee_stage": "yellow"
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 10000000,
          "n": 1
        },
        "outputs": [
          {
            "label": "scene",
            "state": {
              "mode": "marquee",
              "target_color_name": "blue",
              "target_color": 255,
              "visible_color": 16776960,
              "transitioning": true,
              "marquee_stage": "blue"
            }
          }
        ]
      }
    ]
  }
}
