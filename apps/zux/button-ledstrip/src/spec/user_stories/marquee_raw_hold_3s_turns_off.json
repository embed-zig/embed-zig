{
  "kind": "UserStory",
  "spec": {
    "name": "marquee raw hold 3s turns off",
    "description": "Holding the raw Power button while marquee is active emits a 3s long press and turns the strip off.",
    "initial_state": {
      "boot": {},
      "strip": {},
      "scene": {
        "mode": "marquee",
        "target_color_name": "red",
        "target_color": 16711680,
        "visible_color": 16711680,
        "transitioning": false,
        "marquee_stage": "red"
      }
    },
    "steps": [
      {
        "inputs": [
          {
            "raw_single_button": {
              "source_id": 1,
              "pressed": true
            }
          }
        ],
        "outputs": [
          {
            "label": "scene",
            "state": {
              "mode": "marquee",
              "target_color_name": "red",
              "target_color": 16711680,
              "visible_color": 16711680,
              "transitioning": false,
              "marquee_stage": "red"
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 3000000000,
          "n": 1
        },
        "outputs": [
          {
            "label": "boot",
            "state": {
              "source_id": 1,
              "button_id": null,
              "gesture_kind": "long_press",
              "click_count": 0,
              "long_press": 3000000000
            }
          },
          {
            "label": "scene",
            "state": {
              "mode": "off",
              "target_color_name": "none",
              "target_color": 0,
              "visible_color": 0,
              "transitioning": false,
              "marquee_stage": "none"
            }
          }
        ]
      }
    ]
  }
}
