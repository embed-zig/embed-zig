{
  "kind": "UserStory",
  "spec": {
    "name": "color lerps on tick",
    "description": "A tick moves visible color one interpolation step toward the target color.",
    "initial_state": {
      "button": {},
      "strip": {},
      "scene": {
        "mode": "solid",
        "target_color_name": "blue",
        "target_color": 255,
        "visible_color": 16711680,
        "transitioning": true,
        "marquee_stage": "none"
      }
    },
    "steps": [
      {
        "outputs": [
          {
            "label": "scene",
            "state": {
              "mode": "solid",
              "target_color_name": "blue",
              "target_color": 255,
              "visible_color": 16711680,
              "transitioning": true,
              "marquee_stage": "none"
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 10000000,
          "n": 1
        },
        "outputs": [
          {
            "label": "scene",
            "state": {
              "mode": "solid",
              "target_color_name": "blue",
              "target_color": 255,
              "visible_color": 15663120,
              "transitioning": true,
              "marquee_stage": "none"
            }
          }
        ]
      }
    ]
  }
}
