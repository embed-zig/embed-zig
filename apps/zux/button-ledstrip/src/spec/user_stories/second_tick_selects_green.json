{
  "kind": "UserStory",
  "spec": {
    "name": "second tick selects green",
    "description": "When the first scene step has completed, the user waits for the second tick and the strip turns green",
    "initial_state": {
      "button": {},
      "strip": {},
      "scene": {
        "mode": 0,
        "rainbow_stage": 0
      }
    },
    "steps": [
      {
        "outputs": [
          {
            "label": "scene",
            "state": {
              "mode": 0,
              "rainbow_stage": 0
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 120000000,
          "n": 2
        },
        "outputs": [
          {
            "label": "scene",
            "state": {
              "mode": 2,
              "rainbow_stage": 0
            }
          }
        ]
      }
    ]
  }
}
