{
  "kind": "UserStory",
  "spec": {
    "name": "marquee hold 5s stays off after 3s",
    "description": "A hold that starts while marquee is already active turns off at 3s and does not re-enter marquee at 5s.",
    "initial_state": {
      "button": {},
      "strip": {},
      "scene": {
        "mode": "marquee",
        "target_color_name": "red",
        "target_color": 16711680,
        "visible_color": 16711680,
        "transitioning": false,
        "marquee_stage": "red"
      }
    },
    "steps": [
      {
        "inputs": [
          {
            "button_gesture": {
              "source_id": 1,
              "gesture": {
                "long_press": 3000000000
              }
            }
          }
        ],
        "outputs": [
          {
            "label": "scene",
            "state": {
              "mode": "off",
              "target_color_name": "none",
              "target_color": 0,
              "visible_color": 0,
              "transitioning": false,
              "marquee_stage": "none"
            }
          }
        ]
      },
      {
        "inputs": [
          {
            "button_gesture": {
              "source_id": 1,
              "gesture": {
                "long_press": 5000000000
              }
            }
          }
        ],
        "outputs": [
          {
            "label": "scene",
            "state": {
              "mode": "off",
              "target_color_name": "none",
              "target_color": 0,
              "visible_color": 0,
              "transitioning": false,
              "marquee_stage": "none"
            }
          }
        ]
      }
    ]
  }
}
