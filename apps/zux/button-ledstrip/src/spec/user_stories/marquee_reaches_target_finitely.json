{
  "kind": "UserStory",
  "spec": {
    "name": "marquee reaches target finitely",
    "description": "A marquee tick that reaches the current target switches to the next target color immediately.",
    "initial_state": {
      "button": {},
      "strip": {},
      "scene": {
        "mode": "marquee",
        "target_color_name": "red",
        "target_color": 16711680,
        "visible_color": 16646144,
        "transitioning": true,
        "marquee_stage": "red"
      }
    },
    "steps": [
      {
        "outputs": [
          {
            "label": "scene",
            "state": {
              "mode": "marquee",
              "target_color_name": "red",
              "target_color": 16711680,
              "visible_color": 16646144,
              "transitioning": true,
              "marquee_stage": "red"
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 10000000,
          "n": 1
        },
        "outputs": [
          {
            "label": "scene",
            "state": {
              "mode": "marquee",
              "target_color_name": "yellow",
              "target_color": 16776960,
              "visible_color": 16711680,
              "transitioning": true,
              "marquee_stage": "yellow"
            }
          }
        ]
      }
    ]
  }
}
