{
  "kind": "UserStory",
  "spec": {
    "name": "marquee reaches target finitely",
    "description": "Repeated marquee ticks reach the current target in finite time and switch to the next target.",
    "initial_state": {
      "button": {},
      "strip": {},
      "scene": {
        "mode": "marquee",
        "target_color_name": "red",
        "target_color": 16711680,
        "visible_color": 0,
        "transitioning": true,
        "marquee_stage": "red"
      }
    },
    "steps": [
      {
        "outputs": [
          {
            "label": "scene",
            "state": {
              "mode": "marquee",
              "target_color_name": "red",
              "target_color": 16711680,
              "visible_color": 0,
              "transitioning": true,
              "marquee_stage": "red"
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 10000000,
          "n": 53
        },
        "outputs": [
          {
            "label": "scene",
            "state": {
              "mode": "marquee",
              "target_color_name": "green",
              "target_color": 65280,
              "visible_color": 16711680,
              "transitioning": true,
              "marquee_stage": "green"
            }
          }
        ]
      }
    ]
  }
}
