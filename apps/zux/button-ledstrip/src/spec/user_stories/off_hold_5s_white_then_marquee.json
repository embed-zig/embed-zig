{
  "kind": "UserStory",
  "spec": {
    "name": "off hold 5s white then marquee",
    "description": "Holding Power for 5s while off turns white at 3s and enters marquee at 5s.",
    "initial_state": {
      "button": {},
      "strip": {},
      "scene": {
        "mode": "off",
        "target_color_name": "none",
        "target_color": 0,
        "visible_color": 0,
        "transitioning": false,
        "marquee_stage": "none"
      }
    },
    "steps": [
      {
        "outputs": [
          {
            "label": "scene",
            "state": {
              "mode": "off",
              "target_color_name": "none",
              "target_color": 0,
              "visible_color": 0,
              "transitioning": false,
              "marquee_stage": "none"
            }
          }
        ]
      },
      {
        "inputs": [
          {
            "button_gesture": {
              "source_id": 1,
              "gesture": {
                "long_press": 3000000000
              }
            }
          }
        ],
        "outputs": [
          {
            "label": "scene",
            "state": {
              "mode": "solid",
              "target_color_name": "white",
              "target_color": 16777215,
              "visible_color": 16777215,
              "transitioning": false,
              "marquee_stage": "none"
            }
          }
        ]
      },
      {
        "inputs": [
          {
            "button_gesture": {
              "source_id": 1,
              "gesture": {
                "long_press": 5000000000
              }
            }
          }
        ],
        "outputs": [
          {
            "label": "scene",
            "state": {
              "mode": "marquee",
              "target_color_name": "red",
              "target_color": 16711680,
              "visible_color": 16777215,
              "transitioning": true,
              "marquee_stage": "red"
            }
          }
        ]
      }
    ]
  }
}
