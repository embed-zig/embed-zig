{
  "kind": "UserStory",
  "spec": {
    "name": "marquee hold after 5s keeps progress",
    "description": "Repeated long-press events from the same hold that entered marquee keep the in-flight color progress.",
    "initial_state": {
      "boot": {},
      "strip": {},
      "scene": {
        "mode": "solid",
        "target_color_name": "blue",
        "target_color": 255,
        "visible_color": 255,
        "transitioning": false,
        "marquee_stage": "none"
      }
    },
    "steps": [
      {
        "inputs": [
          {
            "button_gesture": {
              "source_id": 1,
              "gesture": {
                "long_press": 3000000000
              }
            }
          }
        ],
        "outputs": [
          {
            "label": "scene",
            "state": {
              "mode": "off",
              "target_color_name": "none",
              "target_color": 0,
              "visible_color": 0,
              "transitioning": false,
              "marquee_stage": "none"
            }
          }
        ]
      },
      {
        "inputs": [
          {
            "button_gesture": {
              "source_id": 1,
              "gesture": {
                "long_press": 5000000000
              }
            }
          }
        ],
        "outputs": [
          {
            "label": "scene",
            "state": {
              "mode": "marquee",
              "target_color_name": "red",
              "target_color": 16711680,
              "visible_color": 0,
              "transitioning": true,
              "marquee_stage": "red"
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 10000000,
          "n": 1
        },
        "outputs": [
          {
            "label": "scene",
            "state": {
              "mode": "marquee",
              "target_color_name": "red",
              "target_color": 16711680,
              "visible_color": 1048576,
              "transitioning": true,
              "marquee_stage": "red"
            }
          }
        ]
      },
      {
        "inputs": [
          {
            "button_gesture": {
              "source_id": 1,
              "gesture": {
                "long_press": 5010000000
              }
            }
          }
        ],
        "outputs": [
          {
            "label": "scene",
            "state": {
              "mode": "marquee",
              "target_color_name": "red",
              "target_color": 16711680,
              "visible_color": 1048576,
              "transitioning": true,
              "marquee_stage": "red"
            }
          }
        ]
      }
    ]
  }
}
