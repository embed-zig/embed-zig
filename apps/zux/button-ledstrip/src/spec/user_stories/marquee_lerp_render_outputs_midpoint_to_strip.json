{
  "kind": "UserStory",
  "spec": {
    "name": "marquee lerp render outputs midpoint to strip",
    "description": "Render writes the first marquee interpolation midpoint to the actual LED strip pixel.",
    "initial_state": {
      "button": {},
      "strip": {},
      "scene": {
        "mode": "marquee",
        "target_color_name": "red",
        "target_color": 16711680,
        "visible_color": 0,
        "transitioning": true,
        "marquee_stage": "red"
      }
    },
    "steps": [
      {
        "tick": {
          "interval": 10000000,
          "n": 1
        },
        "outputs": [
          {
            "label": "scene",
            "state": {
              "visible_color": 1048576,
              "transitioning": true
            }
          },
          {
            "label": "strip_pixel0",
            "state": {
              "r": 16,
              "g": 0,
              "b": 0
            }
          }
        ]
      }
    ]
  }
}
