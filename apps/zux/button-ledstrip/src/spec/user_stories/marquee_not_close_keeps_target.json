{
  "kind": "UserStory",
  "spec": {
    "name": "marquee not close keeps target",
    "description": "If marquee is not close to the current target, the next 10ms tick keeps the same target.",
    "initial_state": {
      "button": {},
      "strip": {},
      "scene": {
        "mode": "marquee",
        "target_color_name": "red",
        "target_color": 16711680,
        "visible_color": 0,
        "transitioning": true,
        "marquee_stage": "red"
      }
    },
    "steps": [
      {
        "outputs": [
          {
            "label": "scene",
            "state": {
              "mode": "marquee",
              "target_color_name": "red",
              "target_color": 16711680,
              "visible_color": 0,
              "transitioning": true,
              "marquee_stage": "red"
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 10000000,
          "n": 1
        },
        "outputs": [
          {
            "label": "scene",
            "state": {
              "mode": "marquee",
              "target_color_name": "red",
              "target_color": 16711680,
              "visible_color": 1048576,
              "transitioning": true,
              "marquee_stage": "red"
            }
          }
        ]
      }
    ]
  }
}
