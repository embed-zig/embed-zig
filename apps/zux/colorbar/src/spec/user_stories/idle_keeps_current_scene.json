{
  "kind": "UserStory",
  "spec": {
    "name": "idle keeps current scene",
    "description": "Without a boot click, scene.current stays unchanged.",
    "initial_state": {
      "boot": {},
      "display": {
        "enabled": true,
        "brightness": 255
      },
      "scene": {
        "current": "green"
      }
    },
    "steps": [
      {
        "outputs": [
          {
            "label": "scene",
            "state": {
              "current": "green"
            }
          }
        ]
      }
    ]
  }
}
