{
  "kind": "UserStory",
  "spec": {
    "name": "single click advances once",
    "description": "A single boot click advances exactly one scene and does not skip colors.",
    "initial_state": {
      "boot": {},
      "display": {
        "enabled": true,
        "brightness": 255
      },
      "scene": {
        "current": "split_7_colors"
      }
    },
    "steps": [
      {
        "inputs": [
          {
            "button_gesture": {
              "source_id": 1,
              "gesture": {
                "click": 1
              }
            }
          }
        ],
        "outputs": [
          {
            "label": "scene",
            "state": {
              "current": "red"
            }
          },
          {
            "label": "display_driver",
            "state": {
              "rendered": true
            }
          }
        ]
      }
    ]
  }
}
