{
  "kind": "UserStory",
  "spec": {
    "name": "third tick selects blue",
    "description": "When the second scene step has completed, the user waits for the third tick and the strip turns blue",
    "initial_state": {
      "button": {},
      "strip": {},
      "scene": {
        "mode": 0,
        "rainbow_stage": 0,
        "next_rainbow_step_ns": 0
      }
    },
    "steps": [
      {
        "outputs": [
          {
            "label": "scene",
            "state": {
              "mode": 0,
              "rainbow_stage": 0
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 120000000,
          "n": 3
        },
        "outputs": [
          {
            "label": "scene",
            "state": {
              "mode": 3,
              "rainbow_stage": 0
            }
          }
        ]
      }
    ]
  }
}
