{
  "kind": "UserStory",
  "spec": {
    "name": "initial tick keeps strip off",
    "description": "When the LED strip is off, the user waits for the first tick and the strip remains off",
    "initial_state": {
      "button": {},
      "strip": {},
      "scene": {
        "mode": 0,
        "rainbow_stage": 0,
        "next_rainbow_step_ns": 0
      }
    },
    "steps": [
      {
        "outputs": [
          {
            "label": "scene",
            "state": {
              "mode": 0,
              "rainbow_stage": 0
            }
          }
        ]
      },
      {
        "tick": {
          "interval": 120000000,
          "n": 1
        },
        "outputs": [
          {
            "label": "scene",
            "state": {
              "mode": 1,
              "rainbow_stage": 0
            }
          }
        ]
      }
    ]
  }
}
